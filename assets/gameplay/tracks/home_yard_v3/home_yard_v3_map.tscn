},
"to_floor": "upper",
"type": "u_shaped_residential_stair",
"upper_landing_center": Vector3(82, 52.6, 134),
"upper_zone": "upper_front_hall",
"validation_gate": "must not intersect route corridors, exterior shell, or camera views; lower and upper flights must be separated in plan with no tread/stringer overlap, visible risers, landings, stringers, railings, clear approach volumes, and no floor/ceiling slab covering the stair path"
}, {
"collision_policy": "visual_reference_no_gameplay_collision",
"continuity_gate": "ladder rungs and rails must span upper hall floor datum to attic floor datum and overlap the hatch opening",
"from_floor": "upper",
"id": "AtticPullDownStairUpperHallToAttic",
"lower_landing_center": Vector3(24, 52.6, -54),
